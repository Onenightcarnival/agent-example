# 复制为 .env 后填写。不要提交真实密钥。
MODEL_BASE_URL=https://api.deepseek.com
MODEL_API_KEY=xxxx
MODEL_NAME=deepseek-v4-flash
# 可选：13_model_routing 示例会优先读取这两个模型名。
# 不填写时，默认使用 deepseek-v4-flash 和 deepseek-v4-pro。
# MODEL_SIMPLE_NAME=deepseek-v4-flash
# MODEL_COMPLEX_NAME=deepseek-v4-pro
MODEL_TIMEOUT_SECONDS=30

SANDBOX_MCP_SERVER_URL=http://localhost:8080/mcp
# 可选：远程 sandbox 需要鉴权时填写。
# SANDBOX_MCP_AUTH_HEADER="Authorization: Bearer xxxx"

# PostgreSQL 连接配置。这里假设普通关系表和 pgvector 向量表共用同一个库。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deepagents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 可选：需要 Langfuse 观测时再填写。
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=development
